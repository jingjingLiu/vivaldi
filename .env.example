# =============================================================
# Vivaldi — environment variables template
# Copy to `.env` and adjust. `.env` is gitignored.
# =============================================================

# ---- MySQL (docker-compose) ----
MYSQL_ROOT_PASSWORD=root_dev_pwd
MYSQL_DATABASE=vivaldi
MYSQL_USER=vivaldi
MYSQL_PASSWORD=vivaldi_dev_pwd
MYSQL_PORT=3306
TZ=Asia/Shanghai

# ---- Prisma / backend ----
# Format: mysql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL="mysql://vivaldi:vivaldi_dev_pwd@localhost:3306/vivaldi"

# ---- Backend runtime (placeholders; filled in when backend is scaffolded) ----
NODE_ENV=development
PORT=3000
JWT_SECRET=change_me_dev_secret
JWT_EXPIRES_IN=2h
